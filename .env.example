# Vercel KV（進捗同期バックアップ用）
# Vercel ダッシュボードで KV ストアを作成後、自動設定される
# ローカル開発時: vercel env pull .env.local
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# AdSense GPT 手動スロット（Reflec-Shot ラボ /lab/reflec-shot）。未設定時は開発ビルドでプレースホルダー表示
# NEXT_PUBLIC_ADSENSE_SLOT_REFLEC_SHOT_1=
# NEXT_PUBLIC_ADSENSE_SLOT_REFLEC_SHOT_2=
# AdSense GPT（スカイスクレイパー /games/skyscraper）
# NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER_1=
# NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER_2=
# 任意: 発行者 ID（既定 ca-pub-5383262801288621）
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
